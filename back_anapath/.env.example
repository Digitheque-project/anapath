NODE_ENV=development
PORT=3334

# Base de données PostgreSQL — connection string complète
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE

# CORS (origines supplémentaires autorisées, séparées par des virgules)
CORS_ORIGINS=http://localhost:3031

# Services externes
ANAPATH_SERVICE_ID=
CHU_SERVICE_URL=
ACCUEIL_BASE_URL=
NOTIF_SERVICE_URL=

# Écosystème d'authentification partagé (auth-service / user-services)
AUTH_ANAPATH_SERVICE_ID=
USER_SERVICES_URL=
AUTH_TOKEN_CACHE_TTL_MS=60000
